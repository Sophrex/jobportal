# Backend
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://localhost:5432/jobportal
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Frontend (copy to frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WAGTAIL_API_URL=http://localhost:8000/api/v2

# Admin (copy to admin/.env)
VITE_API_URL=http://localhost:8000

# Mobile (copy to mobile/.env)
# Use your machine's LAN IP instead of localhost for physical devices
EXPO_PUBLIC_API_URL=http://localhost:8000
